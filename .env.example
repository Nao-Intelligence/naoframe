# Supabase (Database + Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Postgres connection strings (from Supabase -> Project Settings -> Database)
# Use the Session Pooler URL (port 5432) for runtime queries.
DATABASE_URL=postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Use the direct connection URL for drizzle-kit migrations (port 5432, no pooler).
DIRECT_DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-REF.supabase.co:5432/postgres

# OpenAI (Whisper transcription)
OPENAI_API_KEY=sk-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Storage bucket name for uploaded audio
SUPABASE_AUDIO_BUCKET=feedback-audio

# Supabase Storage bucket for uploaded HTML wireframe bundles (must be public)
SUPABASE_WIREFRAME_BUCKET=wireframes
